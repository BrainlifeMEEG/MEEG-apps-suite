# Brainlife.io MEG/EEG App Suite - Git Submodules Configuration

# ============================================================================
# Data Conversion Apps (Convert various formats to MNE .fif files)
# ============================================================================

[submodule "app-bdf2mne"]
	path = bdf2mne
	url = https://github.com/BrainlifeMEEG/bdf2mne.git

